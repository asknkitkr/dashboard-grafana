{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1000,
      "title": "📊 Cluster Overview & Point-in-Time Health",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "count(kube_node_info)", "legendFormat": "Nodes", "refId": "A" }],
      "title": "Total Nodes",
      "description": "X: N/A | Y: Count of nodes in cluster",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\"}[$interval])) / sum(kube_node_status_allocatable{resource=\"cpu\"})", "legendFormat": "CPU %", "refId": "A" }],
      "title": "Cluster CPU Util",
      "description": "X: N/A | Y: Percentage of allocatable CPU used",
      "type": "gauge"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 78 }, { "color": "red", "value": 85 }] },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(container_memory_working_set_bytes{namespace=~\"$namespace\"}) / sum(kube_node_status_allocatable{resource=\"memory\"})", "legendFormat": "Mem %", "refId": "A" }],
      "title": "Cluster Mem Util",
      "description": "X: N/A | Y: Percentage of allocatable memory used",
      "type": "gauge"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 3 }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[$interval]))", "legendFormat": "Restarts", "refId": "A" }],
      "title": "Pod Restarts",
      "description": "X: N/A | Y: Restart count in selected range",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 1 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(increase(kube_pod_container_status_terminated_reason{reason=\"OOMKilled\", namespace=~\"$namespace\"}[$interval]))", "legendFormat": "OOM", "refId": "A" }],
      "title": "OOMKilled",
      "description": "X: N/A | Y: OOM termination count",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 1 },
      "id": 28,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(kube_pod_container_status_waiting_reason{reason=\"CrashLoopBackOff\", namespace=~\"$namespace\"})", "legendFormat": "CrashLoop", "refId": "A" }],
      "title": "CrashLoopBackOff",
      "description": "X: N/A | Y: Pods currently in CrashLoopBackOff",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "id": 100,
      "options": { "showHeader": true, "sortBy": [{ "desc": true, "displayName": "CPU (cores)" }] },
      "targets": [
        { "expr": "sum by (deployment) (rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\", pod=~\"$deployment.*\"}[$interval]))", "format": "table", "instant": true, "legendFormat": "CPU", "refId": "A" },
        { "expr": "sum by (deployment) (container_memory_working_set_bytes{namespace=~\"$namespace\", pod=~\"$deployment.*\"})", "format": "table", "instant": true, "legendFormat": "Memory", "refId": "B" },
        { "expr": "sum by (deployment) (kube_pod_container_status_restarts_total{namespace=~\"$namespace\", pod=~\"$deployment.*\"})", "format": "table", "instant": true, "legendFormat": "Restarts", "refId": "C" },
        { "expr": "min by (deployment) (kube_pod_status_ready{namespace=~\"$namespace\", pod=~\"$deployment.*\"})", "format": "table", "instant": true, "legendFormat": "Ready", "refId": "D" }
      ],
      "title": "🎯 Current State of All Services (Point-in-Time)",
      "description": "Tabular snapshot: Deployment, CPU Cores, Memory Bytes, Restarts, Ready (1=Yes/0=No). Sorted by CPU desc.",
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value #A": "CPU (cores)", "Value #B": "Memory (bytes)", "Value #C": "Restarts", "Value #D": "Ready", "deployment": "Deployment" } } }
      ],
      "type": "table"
    },
    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 1001,
      "title": "☸️ Kubernetes Resources & Quotas",
      "type": "row",
      "panels": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "fieldConfig": { "defaults": { "unit": "percent", "custom": { "axisLabel": "Utilization %" } } },
          "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
          "id": 7,
          "targets": [{ "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\"}[$interval])) by (namespace) / sum(kube_pod_container_resource_limits{resource=\"cpu\", namespace=~\"$namespace\"}) by (namespace) * 100", "legendFormat": "{{namespace}}", "refId": "A" }],
          "title": "Namespace CPU Util vs Limits",
          "description": "X: Time | Y: % of CPU limit consumed per namespace",
          "type": "timeseries"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "fieldConfig": { "defaults": { "unit": "percent", "custom": { "axisLabel": "Utilization %" } } },
          "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
          "id": 8,
          "targets": [{ "expr": "sum(container_memory_working_set_bytes{namespace=~\"$namespace\"}) by (namespace) / sum(kube_pod_container_resource_limits{resource=\"memory\", namespace=~\"$namespace\"}) by (namespace) * 100", "legendFormat": "{{namespace}}", "refId": "A" }],
          "title": "Namespace Mem Util vs Limits",
          "description": "X: Time | Y: % of memory limit consumed per namespace",
          "type": "timeseries"
        }
      ]
    },
    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 1002,
      "title": "🚀 Pod & Container Health Deep Dive",
      "type": "row",
      "panels": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "fieldConfig": { "defaults": { "unit": "short", "custom": { "axisLabel": "CPU Cores" } } },
          "gridPos": { "h": 7, "w": 12, "x": 0, "y": 15 },
          "id": 11,
          "targets": [{ "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\", pod=~\"$pod\", container!=\"POD\"}[$interval]))", "legendFormat": "{{pod}}", "refId": "A" }],
          "title": "CPU Usage by Pod",
          "description": "X: Time | Y: CPU cores consumed per pod",
          "type": "timeseries"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "axisLabel": "Memory Bytes" } } },
          "gridPos": { "h": 7, "w": 12, "x": 12, "y": 15 },
          "id": 18,
          "targets": [{ "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=~\"$namespace\", pod=~\"$pod\", container!=\"POD\"})", "legendFormat": "{{pod}}", "refId": "A" }],
          "title": "Memory Working Set by Pod",
          "description": "X: Time | Y: Memory working set bytes per pod",
          "type": "timeseries"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "fieldConfig": { "defaults": { "unit": "s", "custom": { "axisLabel": "Throttled Seconds" } } },
          "gridPos": { "h": 7, "w": 12, "x": 0, "y": 22 },
          "id": 14,
          "targets": [{ "expr": "sum by (pod) (rate(container_cpu_cfs_throttled_seconds_total{namespace=~\"$namespace\", pod=~\"$pod\"}[$interval]))", "legendFormat": "{{pod}}", "refId": "A" }],
          "title": "CPU Throttling by Pod",
          "description": "X: Time | Y: Seconds CPU was throttled due to CFS quota",
          "type": "timeseries"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "axisLabel": "Bytes/sec" } } },
          "gridPos": { "h": 7, "w": 12, "x": 12, "y": 22 },
          "id": 31,
          "targets": [
            { "expr": "sum by (pod) (rate(container_network_receive_bytes_total{namespace=~\"$namespace\", pod=~\"$pod\"}[$interval]))", "legendFormat": "RX {{pod}}", "refId": "A" },
            { "expr": "sum by (pod) (rate(container_network_transmit_bytes_total{namespace=~\"$namespace\", pod=~\"$pod\"}[$interval]))", "legendFormat": "TX {{pod}}", "refId": "B" }
          ],
          "title": "Network I/O by Pod",
          "description": "X: Time | Y: Network receive/transmit bytes per second",
          "type": "timeseries"
        }
      ]
    },
    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 1003,
      "title": "☕ JVM Metrics (Spring Boot)",
      "type": "row",
      "panels": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "axisLabel": "Heap Bytes" } } },
          "gridPos": { "h": 7, "w": 12, "x": 0, "y": 16 },
          "id": 200,
          "targets": [
            { "expr": "sum by (pod) (jvm_memory_used_bytes{namespace=~\"$namespace\", pod=~\"$pod\", area=\"heap\"})", "legendFormat": "Used {{pod}}", "refId": "A" },
            { "expr": "sum by (pod) (jvm_memory_max_bytes{namespace=~\"$namespace\", pod=~\"$pod\", area=\"heap\"})", "legendFormat": "Max {{pod}}", "refId": "B" }
          ],
          "title": "JVM Heap Usage",
          "description": "X: Time | Y: Heap memory used vs max configured bytes",
          "type": "timeseries"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "fieldConfig": { "defaults": { "unit": "short", "custom": { "axisLabel": "GC Events/sec" } } },
          "gridPos": { "h": 7, "w": 12, "x": 12, "y": 16 },
          "id": 201,
          "targets": [{ "expr": "sum by (pod, gc) (rate(jvm_gc_pause_seconds_count{namespace=~\"$namespace\", pod=~\"$pod\"}[$interval]))", "legendFormat": "{{gc}} {{pod}}", "refId": "A" }],
          "title": "JVM GC Activity",
          "description": "X: Time | Y: Garbage collection events per second by type",
          "type": "timeseries"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "fieldConfig": { "defaults": { "unit": "short", "custom": { "axisLabel": "Thread Count" } } },
          "gridPos": { "h": 7, "w": 12, "x": 0, "y": 23 },
          "id": 202,
          "targets": [
            { "expr": "sum by (pod) (jvm_threads_live_threads{namespace=~\"$namespace\", pod=~\"$pod\"})", "legendFormat": "Live {{pod}}", "refId": "A" },
            { "expr": "sum by (pod) (jvm_threads_blocked_threads{namespace=~\"$namespace\", pod=~\"$pod\"})", "legendFormat": "Blocked {{pod}}", "refId": "B" }
          ],
          "title": "JVM Thread State",
          "description": "X: Time | Y: Live vs blocked thread count",
          "type": "timeseries"
        }
      ]
    },
    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 1004,
      "title": "🗄️ Middleware: Kafka, Cassandra, PostgreSQL",
      "type": "row",
      "panels": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "fieldConfig": { "defaults": { "unit": "short", "custom": { "axisLabel": "Messages/sec" } } },
          "gridPos": { "h": 7, "w": 8, "x": 0, "y": 17 },
          "id": 300,
          "targets": [{ "expr": "sum(rate(kafka_server_broker_topic_metrics_messages_in_total{namespace=~\"$namespace\"}[$interval]))", "legendFormat": "Msg In", "refId": "A" }],
          "title": "Kafka Message Throughput",
          "description": "X: Time | Y: Messages ingested per second",
          "type": "timeseries"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "fieldConfig": { "defaults": { "unit": "ms", "custom": { "axisLabel": "Latency (ms)" } } },
          "gridPos": { "h": 7, "w": 8, "x": 8, "y": 17 },
          "id": 301,
          "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(cassandra_client_request_latency_bucket{namespace=~\"$namespace\"}[$interval])) by (le))", "legendFormat": "P99 Read", "refId": "A" }],
          "title": "Cassandra P99 Read Latency",
          "description": "X: Time | Y: 99th percentile read latency in ms",
          "type": "timeseries"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "fieldConfig": { "defaults": { "unit": "short", "custom": { "axisLabel": "Connections" } } },
          "gridPos": { "h": 7, "w": 8, "x": 16, "y": 17 },
          "id": 302,
          "targets": [{ "expr": "sum(pg_stat_activity_count{namespace=~\"$namespace\"}) by (state)", "legendFormat": "{{state}}", "refId": "A" }],
          "title": "PostgreSQL Connections",
          "description": "X: Time | Y: Active/idle connection count",
          "type": "timeseries"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "fieldConfig": { "defaults": { "unit": "short", "custom": { "axisLabel": "Consumer Lag" } } },
          "gridPos": { "h": 7, "w": 12, "x": 0, "y": 24 },
          "id": 303,
          "targets": [{ "expr": "sum(kafka_consumer_group_lag{namespace=~\"$namespace\"}) by (group)", "legendFormat": "{{group}}", "refId": "A" }],
          "title": "Kafka Consumer Lag",
          "description": "X: Time | Y: Message lag per consumer group",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 5000 }] },
          "type": "timeseries"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "axisLabel": "DB Size" } } },
          "gridPos": { "h": 7, "w": 12, "x": 12, "y": 24 },
          "id": 304,
          "targets": [{ "expr": "sum(pg_database_size_bytes{namespace=~\"$namespace\"}) by (datname)", "legendFormat": "{{datname}}", "refId": "A" }],
          "title": "PostgreSQL Database Size",
          "description": "X: Time | Y: Database size in bytes",
          "type": "timeseries"
        }
      ]
    },
    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 1005,
      "title": "🌐 NGINX Ingress & Network",
      "type": "row",
      "panels": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "axisLabel": "Requests/sec" } } },
          "gridPos": { "h": 7, "w": 12, "x": 0, "y": 18 },
          "id": 400,
          "targets": [{ "expr": "sum(rate(nginx_ingress_controller_requests{namespace=~\"$namespace\"}[$interval])) by (status)", "legendFormat": "HTTP {{status}}", "refId": "A" }],
          "title": "NGINX Request Rate by Status",
          "description": "X: Time | Y: HTTP requests/sec by status code",
          "type": "timeseries"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "fieldConfig": { "defaults": { "unit": "s", "custom": { "axisLabel": "Latency (s)" } } },
          "gridPos": { "h": 7, "w": 12, "x": 12, "y": 18 },
          "id": 401,
          "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(nginx_ingress_controller_request_duration_seconds_bucket{namespace=~\"$namespace\"}[$interval])) by (le))", "legendFormat": "P95 Latency", "refId": "A" }],
          "title": "NGINX P95 Response Time",
          "description": "X: Time | Y: 95th percentile response time in seconds",
          "type": "timeseries"
        }
      ]
    },
    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 1006,
      "title": "💾 Storage & PVC Monitoring",
      "type": "row",
      "panels": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "fieldConfig": { "defaults": { "unit": "percent", "custom": { "axisLabel": "Usage %" } } },
          "gridPos": { "h": 7, "w": 12, "x": 0, "y": 19 },
          "id": 500,
          "targets": [{ "expr": "(kubelet_volume_stats_used_bytes{namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"} / kubelet_volume_stats_capacity_bytes{namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"}) * 100", "legendFormat": "{{persistentvolumeclaim}}", "refId": "A" }],
          "title": "PVC Utilization %",
          "description": "X: Time | Y: % of PVC capacity used",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 }] },
          "type": "timeseries"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "axisLabel": "Growth Bytes" } } },
          "gridPos": { "h": 7, "w": 12, "x": 12, "y": 19 },
          "id": 501,
          "targets": [{ "expr": "predict_linear(kubelet_volume_stats_used_bytes{namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"}[6h], 24*3600)", "legendFormat": "24h Predicted {{persistentvolumeclaim}}", "refId": "A" }],
          "title": "PVC Growth Prediction (24h)",
          "description": "X: Time | Y: Predicted storage usage in 24 hours",
          "type": "timeseries"
        }
      ]
    },
    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 1007,
      "title": "📈 Performance KPIs & Long-Term Stability",
      "type": "row",
      "panels": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "fieldConfig": { "defaults": { "unit": "short", "custom": { "axisLabel": "Count / Seconds" } } },
          "gridPos": { "h": 7, "w": 24, "x": 0, "y": 20 },
          "id": 600,
          "targets": [
            { "expr": "sum(rate(http_server_requests_seconds_count{namespace=~\"$namespace\", uri!~\".*health.*|.*metrics.*\"}[$interval]))", "legendFormat": "API Throughput", "refId": "A" },
            { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{namespace=~\"$namespace\", uri!~\".*health.*|.*metrics.*\"}[$interval])) by (le))", "legendFormat": "P95 Latency (s)", "refId": "B" }
          ],
          "title": "API Performance: Throughput vs P95 Latency",
          "description": "X: Time | Y: Left: Req/sec, Right: P95 response time (s)",
          "type": "timeseries"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "axisLabel": "Memory Bytes" } } },
          "gridPos": { "h": 7, "w": 12, "x": 0, "y": 27 },
          "id": 601,
          "targets": [{ "expr": "avg_over_time(container_memory_working_set_bytes{namespace=~\"$namespace\", pod=~\"$pod\"}[6h])", "legendFormat": "6h Avg {{pod}}", "refId": "A" }],
          "title": "Memory Leak Detection (6h Trend)",
          "description": "X: Time | Y: 6-hour moving average of memory usage",
          "type": "timeseries"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "fieldConfig": { "defaults": { "unit": "short", "custom": { "axisLabel": "Restart Count" } } },
          "gridPos": { "h": 7, "w": 12, "x": 12, "y": 27 },
          "id": 25,
          "targets": [{ "expr": "sum by (pod) (increase(kube_pod_container_status_restarts_total{namespace=~\"$namespace\", pod=~\"$pod\"}[$interval]))", "legendFormat": "{{pod}}", "refId": "A" }],
          "title": "Pod Restarts Timeline",
          "description": "X: Time | Y: Cumulative restart count per pod",
          "type": "timeseries"
        }
      ]
    },
    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "id": 1008,
      "title": "🚨 Alerting & Prometheus Health",
      "type": "row",
      "panels": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "fieldConfig": { "defaults": { "unit": "short", "custom": { "axisLabel": "Alert Count" } } },
          "gridPos": { "h": 7, "w": 12, "x": 0, "y": 21 },
          "id": 700,
