  "panels": [
    {
      "collapse": false,
      "collapsed": false,
      "panels": [],
      "title": "Cluster Overview",
      "type": "row",
      "id": 1,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "stat",
      "title": "Total Nodes",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(kube_node_info{cluster=~\"$cluster\"})",
          "format": "time_series",
          "legendFormat": "Total Nodes",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "short",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "id": 2,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      }
    },
    {
      "type": "stat",
      "title": "Ready Nodes",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(kube_node_status_condition{cluster=~\"$cluster\", condition=\"Ready\", status=\"true\"})",
          "format": "time_series",
          "legendFormat": "Ready Nodes",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "short",
