    {
      "type": "timeseries",
      "title": "Cluster CPU Utilization",
      "description": "",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(rate(node_cpu_seconds_total{cluster=~\"$cluster\", mode!=\"idle\"}[5m])) / sum(machine_cpu_cores{cluster=~\"$cluster\"}) * 100",
          "format": "time_series",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisPlacement": "auto",
            "axisLabel": "",
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5
          },
          "unit": "percent"
        }
      },
      "id": 4,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      }
    },
    {
      "type": "timeseries",
      "title": "Cluster Memory Utilization",
      "description": "",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "(sum(node_memory_MemTotal_bytes{cluster=~\"$cluster\"}) - sum(node_memory_MemFree_bytes{cluster=~\"$cluster\"}) - sum(node_memory_Buffers_bytes{cluster=~\"$cluster\"}) - sum(node_memory_Cached_bytes{cluster=~\"$cluster\"})) / sum(node_memory_MemTotal_bytes{cluster=~\"$cluster\"}) * 100",
          "format": "time_series",
          "legendFormat": "Memory %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
