    {
      "type": "timeseries",
      "title": "Namespace CPU Requests vs Limits vs Usage",
      "description": "",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(kube_pod_container_resource_requests{cluster=~\"$cluster\", namespace=~\"$namespace\", resource=\"cpu\"}) by (namespace)",
          "format": "time_series",
          "legendFormat": "Requests {{namespace}}",
          "refId": "A"
        },
        {
          "expr": "sum(kube_pod_container_resource_limits{cluster=~\"$cluster\", namespace=~\"$namespace\", resource=\"cpu\"}) by (namespace)",
          "format": "time_series",
          "legendFormat": "Limits {{namespace}}",
          "refId": "B"
        },
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{cluster=~\"$cluster\", namespace=~\"$namespace\", container!=\"\", pod!=\"\"}[5m])) by (namespace)",
          "format": "time_series",
          "legendFormat": "Usage {{namespace}}",
          "refId": "C"
