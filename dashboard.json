    {
      "id": 7,
      "title": "Namespace CPU Utilization %",
      "type": "timeseries",
      "gridPos": {
        "id": 7,
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\", container!=\"POD\", container!=\"\"}[$interval])) by (namespace) / sum(kube_pod_container_resource_limits{resource=\"cpu\", namespace=~\"$namespace\"}) by (namespace) * 100",
          "legendFormat": "{{namespace}}{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "axisLabel": "Namespace CPU Utilization % (%)"
          }
        }
      },
      "description": "Displays Namespace CPU Utilization %. X-Axis represents Time. Y-Axis represents the metric value over time."
    },
