        "id": 5,
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(increases(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[$interval]))",
