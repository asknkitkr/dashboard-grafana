{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Running Pods",
      "type": "stat",
      "gridPos": {
        "id": 1,
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(kube_pod_status_phase{phase=\"Running\", namespace=~\"$namespace\"})",
          "legendFormat": "Running Pods",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "description": "Displays Running Pods. This is a single statistic panel showing the latest or aggregated value for the selected time range."
    },
    {
      "id": 2,
      "title": "Total CPU Usage (cores)",
      "type": "stat",
      "gridPos": {
        "id": 2,
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\", container!=\"POD\", container!=\"\"}[$interval]))",
          "legendFormat": "Total CPU Usage (cores)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "description": "Displays Total CPU Usage (cores). This is a single statistic panel showing the latest or aggregated value for the selected time range."
    },
